
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARENT
  MENTOR
}

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  password    String
  role        Role
  createdAt   DateTime  @default(now())
  
  students    Student[]
}

model Student {
  id          String  @id @default(uuid())
  name        String
  parentId    String

  parent      User @relation(fields: [parentId], references: [id])
}